        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "storage/introduction",
              "storage/installation"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "storage/storage-sdk",
              "storage/merkle-trees",
              "storage/kv-storage",
              "storage/large-files",
              "storage/error-handling"
            ]
          }
